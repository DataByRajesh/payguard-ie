# Copy to .env.test for the Playwright e2e suite (`pnpm test:e2e`), which runs against a
# dedicated `payguard_test` database so it never touches your interactive dev data.
DATABASE_URL="postgresql://payguard:payguard@localhost:5432/payguard_test"

# The Vitest unit/integration suite (`pnpm test`) uses a third, separate database
# (payguard_vitest) via its own .env.vitest file, for the same reason — copy this file to
# .env.vitest too and change only the database name if you need to recreate it from scratch.

# Leave SESSION_SECRET unset here: both the Playwright test runner (tests/e2e/fixtures/auth.ts,
# which signs cookies directly) and the prebuilt server it drives (playwright.config.ts webServer)
# need to agree on the same secret to verify each other's cookies, and the shared local-dev
# fallback in lib/auth/session.ts already guarantees that as long as neither process sets it.
