# Template only -- never commit real production values. This is provisioned in Phase 1B (cloud
# demo deployment) as a Vercel Production environment variable, not as a local .env file.
#
# Expected to be a managed Postgres connection string (Vercel Postgres / Neon), with `sslmode`
# required since these are always remote, encrypted connections:
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

# Required on the public demo (both Preview and Production) — disables every mutating Server
# Action, since there is no authentication anywhere in this app. See docs/CLOUD_DEPLOYMENT.md
# and docs/SECURITY_AND_LIMITATIONS.md. Never set this locally.
DEMO_READ_ONLY="true"
