# Template only -- never commit real production values. This is provisioned in Phase 1B (cloud
# demo deployment) as a Vercel Production environment variable, not as a local .env file.
#
# Expected to be a managed Postgres connection string (Vercel Postgres / Neon), with `sslmode`
# required since these are always remote, encrypted connections:
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

# Required on the public demo (both Preview and Production) — disables every mutating Server
# Action regardless of who's logged in. See docs/CLOUD_DEPLOYMENT.md and
# docs/SECURITY_AND_LIMITATIONS.md. Never set this locally.
DEMO_READ_ONLY="true"

# A real, random value -- distinct per environment, never the local-dev fallback baked into
# lib/auth/session.ts. Generate with: openssl rand -base64 32
SESSION_SECRET="<generate-a-distinct-random-value-per-environment>"

# The shared login password to hash into every seeded user when running prisma/seed.ts against
# this environment (docs/CLOUD_DEPLOYMENT.md step 5). Shown on /login so reviewers can sign in.
SEED_USER_PASSWORD="<choose-a-demo-password>"

# Required on Vercel: the local filesystem adapter doesn't work on Vercel's ephemeral,
# per-request filesystem. BLOB_READ_WRITE_TOKEN is auto-provisioned once a Blob store is
# attached to the project (docs/CLOUD_DEPLOYMENT.md step 3) -- do not set it manually.
EVIDENCE_STORAGE_PROVIDER="vercel-blob"
