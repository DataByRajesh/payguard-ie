// PayGuard IE — Prisma schema
// See prisma.config.ts for datasource URL / migration path configuration.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum SettlementStatus {
  PENDING
  SETTLED
  FAILED
  REVERSED
}

enum ExceptionType {
  AMOUNT_MISMATCH
  CURRENCY_MISMATCH
  DUPLICATE_PAYMENT
  MISSING_SETTLEMENT
  DELAYED_SETTLEMENT
  SLA_BREACH
  INVALID_STATUS_COMBINATION
}

enum ExceptionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Sprint 3 lifecycle. Supersedes the Sprint 1/2 OPEN/IN_PROGRESS values.
enum ExceptionStatus {
  NEW
  ASSIGNED
  INVESTIGATING
  AWAITING_INFORMATION
  RESOLVED
  CLOSED
}

enum ExceptionNoteType {
  INVESTIGATION
  CUSTOMER_UPDATE
  TECHNICAL_FINDING
  HANDOVER
  RESOLUTION_NOTE
}

enum RootCauseCategory {
  PROCESSING_CONFIGURATION
  SETTLEMENT_FILE_MISSING
  UPSTREAM_PROVIDER_DELAY
  DUPLICATE_SUBMISSION
  DATA_MAPPING_ERROR
  CURRENCY_CONFIGURATION
  STATUS_SYNCHRONISATION
  MANUAL_PROCESSING_ERROR
  UNKNOWN
  OTHER
}

enum ResolutionAction {
  CORRECTIVE_SETTLEMENT_APPLIED
  PAYMENT_STATUS_CORRECTED
  DUPLICATE_TRANSACTION_CANCELLED
  CONFIGURATION_CORRECTED
  UPSTREAM_PROVIDER_CONFIRMED
  ACCEPTED_OPERATIONAL_EXCEPTION
  NO_ISSUE_FOUND
  OTHER
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum ReconciliationRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ReconciliationRuleType {
  MISSING_SETTLEMENT
  AMOUNT_MISMATCH
  CURRENCY_MISMATCH
  DUPLICATE_PAYMENT
  DELAYED_SETTLEMENT
  STUCK_PAYMENT
  INVALID_STATUS_COMBINATION
}

/// PASS/FAIL (not PASSED/FAILED) per the Sprint 3 spec's exact vocabulary.
enum UATStatus {
  NOT_RUN
  PASS
  FAIL
  BLOCKED
}

enum EvidenceType {
  SCREENSHOT
  LOG_EXTRACT
  QUERY_RESULT
  SIGN_OFF_DOCUMENT
  OTHER
}

model Customer {
  id          String   @id @default(cuid())
  customerRef String   @unique
  displayName String
  country     String
  createdAt   DateTime @default(now())

  payments Payment[]
}

model Payment {
  id                   String        @id @default(cuid())
  paymentReference     String        @unique
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id])
  amountMinor           Int
  currency              String
  paymentMethod         String
  status                PaymentStatus
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  expectedSettlementAt  DateTime

  settlement            Settlement?
  exceptionCases        ExceptionCase[]
  reconciliationResults ReconciliationResult[]

  @@index([status])
  @@index([customerId])
}

model Settlement {
  id                   String           @id @default(cuid())
  settlementReference  String           @unique
  paymentId            String           @unique
  payment               Payment          @relation(fields: [paymentId], references: [id])
  amountMinor           Int
  currency              String
  status                SettlementStatus
  settledAt             DateTime?
  sourceFileReference   String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  reconciliationResults ReconciliationResult[]
}

model ReconciliationRun {
  id                String                  @id @default(cuid())
  runReference      String                  @unique
  status            ReconciliationRunStatus
  startedAt         DateTime                @default(now())
  completedAt       DateTime?
  totalPayments     Int
  totalSettlements  Int
  totalResults      Int
  passedCount       Int
  failedCount       Int
  exceptionsCreated Int
  countsByRule      String
  countsBySeverity  String
  errorMessage      String?

  results ReconciliationResult[]
}

model ReconciliationResult {
  id                  String                 @id @default(cuid())
  reconciliationRunId String
  reconciliationRun   ReconciliationRun      @relation(fields: [reconciliationRunId], references: [id])
  paymentId           String
  payment             Payment                @relation(fields: [paymentId], references: [id])
  settlementId        String?
  settlement          Settlement?            @relation(fields: [settlementId], references: [id])
  ruleType            ReconciliationRuleType
  passed              Boolean
  severity            ExceptionSeverity?
  summary             String
  expectedValue       String?
  actualValue         String?
  differenceMinor     Int?
  metadata            String?
  exceptionCaseId     String?
  exceptionCase       ExceptionCase?         @relation(fields: [exceptionCaseId], references: [id])
  createdAt           DateTime               @default(now())

  @@index([paymentId])
  @@index([reconciliationRunId])
  @@index([exceptionCaseId])
}

model ExceptionCase {
  id            String            @id @default(cuid())
  caseReference String            @unique
  paymentId     String
  payment       Payment           @relation(fields: [paymentId], references: [id])
  type          ExceptionType
  severity      ExceptionSeverity
  status        ExceptionStatus
  title         String
  description   String

  assignedUserId   String?
  assignedUser     User?     @relation("ExceptionAssignedUser", fields: [assignedUserId], references: [id])
  assignedAt       DateTime?
  assignedByUserId String?
  assignedByUser   User?     @relation("ExceptionAssignedByUser", fields: [assignedByUserId], references: [id])
  assignmentNote   String?

  rootCauseCategory         RootCauseCategory?
  rootCauseSummary          String?
  rootCauseIdentifiedById   String?
  rootCauseIdentifiedByUser User?              @relation("ExceptionRootCauseUser", fields: [rootCauseIdentifiedById], references: [id])
  rootCauseIdentifiedAt     DateTime?

  resolutionAction  ResolutionAction?
  resolutionSummary String?
  resolutionUserId  String?
  resolutionUser    User?             @relation("ExceptionResolutionUser", fields: [resolutionUserId], references: [id])
  resolutionAt      DateTime?

  approvalDecision ApprovalDecision?
  approvalNote     String?
  approverUserId   String?
  approverUser     User?             @relation("ExceptionApproverUser", fields: [approverUserId], references: [id])
  approvalAt       DateTime?

  dedupeKey      String
  lastDetectedAt DateTime  @default(now())
  slaDeadline    DateTime?
  source         String    @default("MANUAL")
  openedAt       DateTime  @default(now())
  resolvedAt     DateTime?
  closedAt       DateTime?
  /// Optimistic-concurrency guard: every mutation must supply the version it read and increment it.
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  comments              ExceptionComment[]
  evidenceRecords       EvidenceRecord[]
  reconciliationResults ReconciliationResult[]
  uatExecutions         UATExecution[]         @relation("UatLinkedException")

  @@index([dedupeKey])
  @@index([status])
  @@index([assignedUserId])
}

/// Append-only investigation notes (renamed in spirit from "comments" to typed notes in Sprint 3).
model ExceptionComment {
  id              String            @id @default(cuid())
  exceptionCaseId String
  exceptionCase   ExceptionCase     @relation(fields: [exceptionCaseId], references: [id])
  noteType        ExceptionNoteType @default(INVESTIGATION)
  authorUserId    String
  authorUser      User              @relation("ExceptionNoteAuthor", fields: [authorUserId], references: [id])
  body            String
  createdAt       DateTime          @default(now())
}

model AuditEvent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  summary    String
  actor      String
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model UATTestCase {
  id                   String   @id @default(cuid())
  testCaseRef          String   @unique
  title                String
  description          String
  requirementReference String?
  preconditions        String?
  steps                String
  expectedResult       String
  area                 String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  executions UATExecution[]
}

model UATExecution {
  id            String      @id @default(cuid())
  uatTestCaseId String
  uatTestCase   UATTestCase @relation(fields: [uatTestCaseId], references: [id])
  status        UATStatus
  executedAt    DateTime?
  testerUserId  String?
  testerUser    User?       @relation("UatTester", fields: [testerUserId], references: [id])
  actualResult  String?
  notes         String?
  createdAt     DateTime    @default(now())

  linkedExceptionCaseId String?
  linkedExceptionCase   ExceptionCase? @relation("UatLinkedException", fields: [linkedExceptionCaseId], references: [id])

  evidenceRecords EvidenceRecord[]
}

model EvidenceRecord {
  id            String       @id @default(cuid())
  evidenceRef   String       @unique
  type          EvidenceType
  title         String
  description   String?
  fileReference String?
  addedByUserId String?
  addedByUser   User?        @relation("EvidenceAddedByUser", fields: [addedByUserId], references: [id])
  capturedAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())

  uatExecutionId  String?
  uatExecution    UATExecution?  @relation(fields: [uatExecutionId], references: [id])
  exceptionCaseId String?
  exceptionCase   ExceptionCase? @relation(fields: [exceptionCaseId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String
  isActive     Boolean  @default(true)
  passwordHash String?
  createdAt    DateTime @default(now())

  assignedExceptions   ExceptionCase[]    @relation("ExceptionAssignedUser")
  assignedByExceptions ExceptionCase[]    @relation("ExceptionAssignedByUser")
  rootCauseExceptions  ExceptionCase[]    @relation("ExceptionRootCauseUser")
  resolvedExceptions   ExceptionCase[]    @relation("ExceptionResolutionUser")
  approvedExceptions   ExceptionCase[]    @relation("ExceptionApproverUser")
  exceptionNotes       ExceptionComment[] @relation("ExceptionNoteAuthor")
  evidenceAdded        EvidenceRecord[]   @relation("EvidenceAddedByUser")
  uatExecutionsAsTester UATExecution[]    @relation("UatTester")
}
