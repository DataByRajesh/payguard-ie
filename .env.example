# Copy this file to .env and adjust as needed.
# Points at the local Postgres started by `pnpm db:local:start` (docker-compose.yml).
DATABASE_URL="postgresql://payguard:payguard@localhost:5432/payguard_dev"

# Signs session cookies (lib/auth/session.ts). Unset falls back to an insecure, publicly-known
# local-dev value -- fine here, never in Preview/Production (see docs/CLOUD_DEPLOYMENT.md).
# SESSION_SECRET="local-dev-insecure-session-secret-change-me"

# Shared login password hashed into every seeded user (prisma/seed.ts). Unset defaults to
# "payguard-demo", shown on the /login page.
# SEED_USER_PASSWORD="payguard-demo"

# Evidence file storage adapter (lib/evidence-storage/adapter.ts). Unset defaults to "local"
# (writes to gitignored .data/evidence/). Only "vercel-blob" needs a value here, and only in
# Preview/Production -- see .env.production.example.
# EVIDENCE_STORAGE_PROVIDER="local"
